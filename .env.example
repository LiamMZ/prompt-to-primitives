# Copy this file to .env and fill in your keys.
# .env is git-ignored and never committed.

# ── LLM providers ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
ANTHROPIC_API_KEY=sk-ant-...

# ── HuggingFace (Molmo2-4B download) ───────────────────────────────────────────
HF_TOKEN=hf_...

# ── Model checkpoints ──────────────────────────────────────────────────────────
MOLMO_CHECKPOINT=allenai/Molmo2-4B
SAM2_CKPT=/path/to/Grounded-SAM-2/checkpoints/sam2.1_hiera_base_plus.pt
SAM2_CFG=configs/sam2.1/sam2.1_hiera_b+.yaml
RAM_CKPT=/path/to/Grounded-SAM-2/ram_checkpoints/ram_plus_swin_large_14m.pth

# ── B1 robot UDP config (optional — overrides defaults in b1_robot_interface) ──
# B1_UDP_LOCAL_PORT=8080
# B1_UDP_SERVER_IP=192.168.12.1
# B1_UDP_SERVER_PORT=8082
# B1_SDK_PATH=/path/to/unitree_legged_sdk
